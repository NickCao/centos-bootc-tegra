From 6332d94891396f9700708563987f715eb028b525 Mon Sep 17 00:00:00 2001
From: Jan Stancek <jstancek@redhat.com>
Date: Tue, 31 Mar 2026 13:01:26 +0200
Subject: [PATCH 04/35] redhat: allow genlog to exclude commits and issues
 based on ref pattern

JIRA: INTERNAL
Upstream Status: RHEL only

In downstream projects we sometimes merge content from other branches.
In general, we want the merged content from other branch to be present
in changelog, but not on Resolves line - other tools depend on it
and it could be interpreted as issue being fixed twice, or it could
also fail the check-in policy.

Introduce two new variables, that allow genlog to exclude refs matching
pattern entirely or just from Resolves line.

The initial implementation is for merge commits, but could be in theory
extended to any commit.

c10s default is:
  CHANGELOG_EXCLUDE_REFS_PATTERN = ""
  RESOLVES_EXCLUDE_REFS_PATTERN = "^Merge tag \S\+ into main"

which means, that changelog will contain all entries, but resolves line
will exclude all issues found in commits reachable from $RESOLVES_EXCLUDE_REFS_PATTERN.

Signed-off-by: Jan Stancek <jstancek@redhat.com>
---
 redhat/Makefile.exports                       |  2 ++
 redhat/Makefile.variables                     | 10 ++++++
 redhat/scripts/genspec/genlog.sh              | 34 ++++++++++++++++++-
 redhat/self-test/data/centos-2585cf9dfaad.el7 |  2 ++
 .../self-test/data/centos-2585cf9dfaad.fc25   |  2 ++
 redhat/self-test/data/centos-78e36f3b0dae.el7 |  2 ++
 .../self-test/data/centos-78e36f3b0dae.fc25   |  2 ++
 redhat/self-test/data/centos-df0cc57e057f.el7 |  2 ++
 .../self-test/data/centos-df0cc57e057f.fc25   |  2 ++
 redhat/self-test/data/centos-fce15c45d3fb.el7 |  2 ++
 .../self-test/data/centos-fce15c45d3fb.fc25   |  2 ++
 redhat/self-test/data/fedora-2585cf9dfaad.el7 |  2 ++
 .../self-test/data/fedora-2585cf9dfaad.fc25   |  2 ++
 redhat/self-test/data/fedora-78e36f3b0dae.el7 |  2 ++
 .../self-test/data/fedora-78e36f3b0dae.fc25   |  2 ++
 redhat/self-test/data/fedora-df0cc57e057f.el7 |  2 ++
 .../self-test/data/fedora-df0cc57e057f.fc25   |  2 ++
 redhat/self-test/data/fedora-fce15c45d3fb.el7 |  2 ++
 .../self-test/data/fedora-fce15c45d3fb.fc25   |  2 ++
 redhat/self-test/data/rhel-2585cf9dfaad.el7   |  2 ++
 redhat/self-test/data/rhel-2585cf9dfaad.fc25  |  2 ++
 redhat/self-test/data/rhel-78e36f3b0dae.el7   |  2 ++
 redhat/self-test/data/rhel-78e36f3b0dae.fc25  |  2 ++
 redhat/self-test/data/rhel-df0cc57e057f.el7   |  2 ++
 redhat/self-test/data/rhel-df0cc57e057f.fc25  |  2 ++
 redhat/self-test/data/rhel-fce15c45d3fb.el7   |  2 ++
 redhat/self-test/data/rhel-fce15c45d3fb.fc25  |  2 ++
 27 files changed, 93 insertions(+), 1 deletion(-)

diff --git a/redhat/Makefile.exports b/redhat/Makefile.exports
index c85c621d60e7..b8dcd3a62eb5 100644
--- a/redhat/Makefile.exports
+++ b/redhat/Makefile.exports
@@ -1,6 +1,7 @@
 EXPORTED_VARS=BUILD \
 	BUILDOPTS \
 	BUMP_RELEASE \
+	CHANGELOG_EXCLUDE_REFS_PATTERN \
 	DERIVATIVE_BUILD \
 	DERIVATIVE_STREAM \
 	DISTBASEVERSION \
@@ -14,6 +15,7 @@ EXPORTED_VARS=BUILD \
 	MARKER \
 	PATCHLIST_URL \
 	REDHAT \
+	RESOLVES_EXCLUDE_REFS_PATTERN \
 	RHDISTDATADIR \
 	RHDISTGIT_BRANCH \
 	RHDISTGIT_CACHE \
diff --git a/redhat/Makefile.variables b/redhat/Makefile.variables
index ffc7d7b8cbca..8d63422715cf 100644
--- a/redhat/Makefile.variables
+++ b/redhat/Makefile.variables
@@ -61,6 +61,16 @@ DISTRO ?=
 # This overrides CONFIG_WERROR to 'y' for all arches.  RHEL requires this variable to be set.
 ENABLE_WERROR ?= 1
 
+# Pattern to match merge commits whose reachable commits should be excluded from changelog entirely.
+# Example: CHANGELOG_EXCLUDE_REFS_PATTERN = ^Merge tag \S\+ into main
+# Empty value means nothing is excluded.
+CHANGELOG_EXCLUDE_REFS_PATTERN ?=
+
+# Pattern to match merge commits whose reachable commits' JIRAs should be excluded from the Resolves: line.
+# Example: RESOLVES_EXCLUDE_REFS_PATTERN = ^Merge tag \S\+ into main
+# Empty value means nothing is excluded.
+RESOLVES_EXCLUDE_REFS_PATTERN ?= ^Merge tag \S\+ into main
+
 # This is the executable for 'git' commands.  It is used by the redhat/self-test
 # tests to provide testing information on git hashes (see redhat/self-test/egit.sh)
 GIT ?= git
diff --git a/redhat/scripts/genspec/genlog.sh b/redhat/scripts/genspec/genlog.sh
index f61199c31fc2..d7f3680ea2fd 100755
--- a/redhat/scripts/genspec/genlog.sh
+++ b/redhat/scripts/genspec/genlog.sh
@@ -35,13 +35,45 @@ fi
 echo "Gathering new log entries since $lasttag"
 # master is expected to track mainline.
 
+commits_to_exclude=()
+issues_to_exclude=""
+
+if [[ -n "$CHANGELOG_EXCLUDE_REFS_PATTERN" ]]; then
+    mapfile -t exclude_cl_commits < <(git log HEAD ^"${UPSTREAM}" ^"${lasttag}" --format=%H \
+        --topo-order --merges --grep="$CHANGELOG_EXCLUDE_REFS_PATTERN")
+    for commit in "${exclude_cl_commits[@]}"; do
+        echo "Ignoring commits reachable from: $(git log -1 --oneline "$commit")"
+        commits_to_exclude+=("^$commit")
+    done
+fi
+
+if [[ -n "$RESOLVES_EXCLUDE_REFS_PATTERN" ]]; then
+    mapfile -t exclude_res_commits < <(git log HEAD ^"${UPSTREAM}" ^"${lasttag}" --format=%H \
+        --topo-order --merges --grep="$RESOLVES_EXCLUDE_REFS_PATTERN")
+    if [[ "${#exclude_res_commits[@]}" -gt 0 ]]; then
+        for commit in "${exclude_res_commits[@]}"; do
+            echo "Ignoring issues in commits reachable from: $(git log -1 --oneline "$commit")"
+        done
+        issues_to_exclude=$(git log --topo-order --no-merges -z "$GIT_FORMAT" \
+            "${exclude_res_commits[@]}" ^"${lasttag}" -- ':!/redhat/rhdocs' |
+            "${0%/*}"/genlog.py | sed -n 's/^Resolves: //p' | sed 's/,//g')
+    fi
+fi
+
 cname="$(git var GIT_COMMITTER_IDENT |sed 's/>.*/>/')"
 cdate="$(LC_ALL=C date +"%a %b %d %Y")"
 cversion="[$DISTBASEVERSION]";
 echo "* $cdate $cname $cversion" > "$clogf"
 
 git log --topo-order --no-merges -z "$GIT_FORMAT" \
-	^"${UPSTREAM}" "$lasttag".. -- ':!/redhat/rhdocs' | "${0%/*}"/genlog.py >> "$clogf"
+    ^"${UPSTREAM}" "${commits_to_exclude[@]}" "$lasttag".. -- ':!/redhat/rhdocs' | "${0%/*}"/genlog.py >> "$clogf"
+
+if [[ -n "$issues_to_exclude" ]]; then
+    for issue in $issues_to_exclude; do
+        echo "Dropping from Resolves line: $issue"
+        sed -i "/^Resolves:/ { s/, ${issue}\b//g; s/${issue}, //g; s/${issue}\b//g; }" "$clogf"
+    done
+fi
 
 if [ "$HIDE_REDHAT" = "1" ]; then
 	grep -v -e "^- \[redhat\]" "$clogf" |
diff --git a/redhat/self-test/data/centos-2585cf9dfaad.el7 b/redhat/self-test/data/centos-2585cf9dfaad.el7
