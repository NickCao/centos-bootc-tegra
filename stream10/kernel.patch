 drivers/pci/controller/pci-aardvark.c                    | 7 ++-----
 drivers/pci/controller/pcie-xilinx-nwl.c                 | 9 ++-------
 drivers/pci/controller/plda/pcie-starfive.c              | 9 ++-------
 drivers/pci/pci.h                                        | 2 ++
 8 files changed, 14 insertions(+), 33 deletions(-)

