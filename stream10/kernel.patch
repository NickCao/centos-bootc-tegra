+
 	if (cis_capable(hdev)) {
 		events[3] |= 0x01;	/* LE CIS Established */
 		if (cis_peripheral_capable(hdev))
diff --git a/net/bluetooth/iso.c b/net/bluetooth/iso.c
index c0ae6c6fbe94..3c568d3d8ac9 100644
--- a/net/bluetooth/iso.c
