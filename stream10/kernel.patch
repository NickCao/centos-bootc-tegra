+	.has_mutex = false,
+	.variant = TEGRA_I2C_VARIANT_DVC,
 };
+#endif
 
 static const struct tegra_i2c_hw_feature tegra30_i2c_hw = {
 	.has_continue_xfer_support = true,
@@ -1682,6 +1728,7 @@ static const struct tegra_i2c_hw_feature tegra30_i2c_hw = {
