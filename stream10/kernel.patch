 };
 
 static const struct tegra_i2c_hw_feature tegra256_i2c_hw = {
@@ -1775,6 +1867,7 @@ static const struct tegra_i2c_hw_feature tegra256_i2c_hw = {
 	.setup_hold_time_hs_mode = 0x030303,
